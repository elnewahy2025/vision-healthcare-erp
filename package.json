{
  "name": "healthcare-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise Healthcare ERP SaaS Platform",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build": "npm run build -w packages/shared && npm run build -w packages/backend && npm run build -w packages/frontend",
    "lint": "npm run lint -w packages/shared && npm run lint -w packages/backend && npm run lint -w packages/frontend",
    "test": "npm run test -w packages/backend",
    "migrate": "npm run migrate -w packages/backend",
    "seed": "npm run seed -w packages/backend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "npm install && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
