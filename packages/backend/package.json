    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.1",
    "knex": "^3.1.0",
    "otplib": "^12.0.1",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "qrcode": "^1.5.4",
    "slugify": "^1.6.6",
    "tsx": "^4.15.0",
    "zod": "^3.23.8"
