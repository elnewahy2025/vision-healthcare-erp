# ============================================
# Vision Healthcare ERP — Environment Template
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# NEVER use example/placeholder values in production.

# --- Server ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
BASE_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vision_erp
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_SSL=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Authentication ---
# Generate with: openssl rand -hex 32
# JWT_SECRET and JWT_REFRESH_SECRET MUST be different values.
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_A_DIFFERENT_openssl_rand_hex_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated list of allowed origins. NEVER use * in production.
CORS_ORIGIN=http://localhost:5173

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=vision-erp

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vision-erp.com

# --- Sentry (Error Monitoring) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- WhatsApp (Business API) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- AI Provider ---
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=
