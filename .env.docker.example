# === DATABASE (used by docker-compose) ===
POSTGRES_DB=healthcare
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# === REDIS ===
REDIS_HOST=redis
REDIS_PORT=6379

# === AUTH (generate strong secrets for production!) ===
JWT_SECRET=change_this_in_production_use_random_64_chars
JWT_REFRESH_SECRET=change_this_in_production_use_random_64_chars

# === STORAGE ===
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=healthcare

# === APP ===
CORS_ORIGIN=*
APP_URL=http://localhost:5173
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
